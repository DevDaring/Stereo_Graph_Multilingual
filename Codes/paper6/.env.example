# Paper 6 environment template. Copy to .env and fill in real values.
# NEVER commit the real .env. Every module loads keys from here, never hard-coded.
# The .env file is git-ignored by the repo-root .gitignore.

# ---- Hugging Face (local decoder/encoder weight download) ----
HUGGINGFACE_TOKEN=

# ===========================================================================
# JUDGE / ANSWER-EXTRACTION PROVIDERS
# PRIMARY  : Gemini 2.5 Flash, 4 GCP keys, round-robin.
# SECONDARY: DeepSeek (selectable; NO automatic fallback).
# TERTIARY : Mistral Small (selectable; NO automatic fallback).
# OpenRouter is an additional selectable provider.
# Round-robin is applied ACROSS the keys of the active provider only.
# ===========================================================================

# ---- PRIMARY: Gemini 2.5 Flash (4 keys, round-robin) ----
# Provide either the GCP_Key* names OR the GEMINI_API_KEY_* names; the config's
# gemini.key_env_vars lists both, and only the ones present are used.
GCP_Key1=
GCP_Key2=
GCP_Key3=
GCP_key4=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# ---- SECONDARY: DeepSeek (2 keys, round-robin) ----
DEEPSEEK_API_KEY_1=
DEEPSEEK_API_KEY_2=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# ---- TERTIARY: Mistral Small (2 keys, round-robin) ----
MISTRAL_API_KEY1=
MISTRAL_API_KEY2=

# ---- OpenRouter (2 keys, round-robin) ----
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
