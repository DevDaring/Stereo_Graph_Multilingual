# Robust_Rerun environment template. Copy the repo-root .env (Codes/paper6/.env)
# or fill these in. NEVER commit the real .env. Only NAMES appear here; the code
# loads values from the environment at runtime. base_url and model ids are NOT
# secrets and live in config/default.yaml, not here.

# ---- Hugging Face (local encoder/decoder weight download) ----
HUGGINGFACE_TOKEN=

# ---- PRIMARY judge: LinkAPI gemini-2.5-pro (single key) ----
Link_Gemini_Cheap_API_Key=

# ---- SECONDARY judge + a black-box subject model: DeepSeek (2 keys, round-robin) ----
DEEPSEEK_API_KEY_1=
DEEPSEEK_API_KEY_2=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# ---- TERTIARY judge: Mistral Small (2 keys, round-robin) ----
MISTRAL_API_KEY1=
MISTRAL_API_KEY2=

# ---- OpenRouter (2 keys, round-robin) - serves llama-3.3-70b and gpt-oss-20b subjects ----
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
